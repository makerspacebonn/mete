.col-6.col-sm-4.col-md-3.col-lg-2.col-xl-2.my-2.active-user
  = link_to user, :title => user.name do
    .card.user-card.text-center
      .card-header
        .inner-header
          %h6= user.name
      .card-body
        = avatar(user)
      .card-footer
        %small.text-muted= "#{count} #{'transaction'.pluralize(count)}"
